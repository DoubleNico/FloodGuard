# Required: generate with `openssl rand -hex 32`
JWT_SECRET=change-this-to-a-long-random-secret

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Dashboard API base URL (the public URL where the backend is reachable)
NUXT_PUBLIC_API_BASE=https://yourdomain.com

# Optional: Copernicus Data Space credentials for satellite data
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Optional: EFAS partner token for full flood forecast access
EFAS_WMS_TOKEN=

# Optional: HTTP request timeout for external APIs (seconds)
REQUEST_TIMEOUT_SECONDS=45
