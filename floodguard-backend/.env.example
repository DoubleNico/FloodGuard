CDSE_CLIENT_ID=replace-with-your-copernicus-oauth-client-id
CDSE_CLIENT_SECRET=replace-with-your-copernicus-oauth-client-secret
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
REQUEST_TIMEOUT_SECONDS=45
EFAS_WMS_URL=https://european-flood.emergency.copernicus.eu/api/wms/
EFAS_WMS_TOKEN=optional-authorised-efas-partner-token
GLOFAS_API_KEY=optional-cds-api-key-for-glofas
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_FLOOD_BASE_URL=https://flood-api.open-meteo.com/v1
FORECAST_INTERVAL_SECONDS=1800
FORECAST_SCHEDULER_ENABLED=1
DATABASE_PATH=floodguard.db
JWT_SECRET=replace-with-a-long-random-secret
